{
  "name": "guident",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "api:start": "node server/llm_proxy.mjs",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "benchmark": "tsc -p tsconfig.node.json && node dist-node/scripts/run_benchmark.js",
    "test:logic": "tsc -p tsconfig.node.json && node --test tests/*.test.mjs",
    "eval:ablations": "python3 -m experiments.ablation_runner",
    "eval:baselines": "python3 -m experiments.baseline_runner",
    "eval:all": "python3 -m experiments.run_all"
  },
  "dependencies": {
    "expo": "~55.0.5",
    "expo-asset": "~55.0.10",
    "expo-camera": "~55.0.10",
    "expo-dev-client": "~55.0.18",
    "expo-file-system": "~55.0.11",
    "expo-image-manipulator": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "jpeg-js": "^0.4.4",
    "llama.rn": "^0.11.4",
    "onnxruntime-react-native": "^1.24.3",
    "openai": "^6.29.0",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-fast-tflite": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
